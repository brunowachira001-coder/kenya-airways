<outdated-browser-modal cookie-name="KQOutdatedBrowserModal" last-updated="Monday, January 1, 0001" :action-required="true">
    <template #modal-content="{ closeModal }">
        <div class="modal-content modal-content--outdated">
            <div class="modal-content__header">
                <p class="modal-content__header-title heading-h5">
                    <i class="icon icon-alert-circle-colour icon--xs" aria-hidden="true"></i>
                    Browser Compatibility Notice
                </p>
                <button role="button"
                        aria-label="Dismiss modal"
                        class="button--text button--icon">
                    <i class="icon icon-close icon--xs" aria-hidden="true"></i>
                </button>
            </div>
            <div class="modal-content__content">
                <p class="heading-h3 m-b--16">
                    The browser you are using is not supported.
                </p>
                <p class="paragraph-body">
                    For the best website experience, please view the website within Google
                    Chrome; Firefox; or Microsoft Edge.
                </p>
                <ul class="list">
                    <li class="item">
                        <i class="icon icon-chrome"></i>
                        <a href="https://www.google.com/chrome/"
                           rel="noopener"
                           role="link"
                           target="_blank"
                           aria-label="Download Google Chrome"
                           class="link modal-content__browser-link paragraph-body text-KQ-Brand-Secondary">
                            <span>Download Google Chrome</span>
                            <i class="icon icon-color--red icon-externalLink"></i>
                        </a>
                    </li>
                    <li class="item">
                        <i class="icon icon-firefox"></i>
                        <a href="https://www.mozilla.org/en-US/firefox/new/"
                           rel="noopener"
                           role="link"
                           target="_blank"
                           aria-label="Download Firefox"
                           class="link modal-content__browser-link paragraph-body text-KQ-Brand-Secondary">
                            <span>Download Firefox</span>
                            <i class="icon icon-color--red icon-externalLink"></i>
                        </a>
                    </li>
                    <li class="item">
                        <i class="icon icon-edge"></i>
                        <a href="https://www.microsoft.com/en-us/edge/download"
                           rel="noopener"
                           role="link"
                           target="_blank"
                           aria-label="Download Microsoft Edge"
                           class="link modal-content__browser-link paragraph-body text-KQ-Brand-Secondary">
                            <span>Download Microsoft Edge</span>
                            <i class="icon icon-color--red icon-externalLink"></i>
                        </a>
                    </li>
                </ul>
            </div>
            <div class="modal-content__footer">
                <button aria-label="Dismiss modal"
                        role="button"
                        class="button--text button--sm"
                        :onClick="closeModal">
                    Not now
                </button>
            </div>
        </div>
    </template>
</outdated-browser-modal>

