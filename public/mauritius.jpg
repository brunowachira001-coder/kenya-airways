    :destination-alerts="[{&quot;origin&quot;:&quot;CDG&quot;,&quot;destination&quot;:&quot;DZA&quot;,&quot;message&quot;:&quot;Please be advised that a passport is mandatory for passengers flying on Kenya Airways from Paris (CDG) to Dzaoudzi (DZA) Mayotte.&quot;},{&quot;origin&quot;:&quot;&quot;,&quot;destination&quot;:&quot;JNB&quot;,&quot;message&quot;:&quot;Notice: Every child under the age of 18&#xA0;who enters or exits South Africa must have both parents&#x27; approval and present a complete birth certificate at the port of entry.\nThe child must have an affidavit completed by the absent parent or parents if they are traveling alone or with only one parent.&quot;},{&quot;origin&quot;:&quot;&quot;,&quot;destination&quot;:&quot;CPT&quot;,&quot;message&quot;:&quot;Notice: Every child under the age of 18&#xA0;who enters or exits South Africa must have both parents&#x27; approval and present a complete birth certificate at the port of entry.\nThe child must have an affidavit completed by the absent parent or parents if they are traveling alone or with only one parent.&quot;}]">
