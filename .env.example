# ============================================================
# KENYA AIRWAYS FLIGHT BOOKING — ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to git.
# All values are strings — do NOT wrap them in quotes.
# ============================================================

# ==================================
# SUPABASE (Optional — falls back to localStorage)
# ==================================
# If not configured the booking flow still works via localStorage.
# Get values from: https://supabase.com/project/_/settings/api
#
# 1. Create a project at https://supabase.com
# 2. In the SQL Editor run: supabase-setup.sql (from project root)
# 3. Go to Settings → API and copy:
#    - Project URL  → NEXT_PUBLIC_SUPABASE_URL
#    - anon public  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - service_role → SUPABASE_SERVICE_ROLE_KEY (server-side only)
#
# npm install @supabase/supabase-js   # only when Supabase is configured
#
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==================================
# PAYNECTA (Live — already configured on production)
# ==================================
# Mobile payments via https://paynecta.co.ke
# Get your credentials from your Paynecta merchant dashboard.
# These are already set in production .env on Vercel.
#
PAYNECTA_API_KEY=your_paynecta_api_key
PAYNECTA_EMAIL=your_paynecta_account_email
PAYNECTA_CODE=your_paynecta_payment_link_code

# ==================================
# NEXTJS
# ==================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================================
# ADMIN AUTHENTICATION (Required)
# ==================================
# Password for accessing /admin dashboard and API
# Generate a strong password: openssl rand -base64 32
ADMIN_PASSWORD=your_secure_admin_password_here

# ==================================
# M-PESA DARAJA API (Optional — Safaricom)
# ==================================
# Register at https://developer.safaricom.co.ke
# MPESA_CONSUMER_KEY=your_mpesa_consumer_key
# MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
# MPESA_SHORTCODE=your_paybill_number
# MPESA_PASSKEY=your_mpesa_passkey

# ==================================
# OTHER PAYMENT GATEWAYS (Optional)
# ==================================
# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ==================================
# EMAIL SERVICE (Optional — SMTP)
# ==================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ==================================
# MAPS (Optional)
# ==================================
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key