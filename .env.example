# ==================================
# KENYA AIRWAYS - ENVIRONMENT VARIABLES
# ==================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git

# ==================================
# SUPABASE CONFIGURATION
# ==================================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==================================
# DATABASE (Optional - if using direct connection)
# ==================================
DATABASE_URL=your_database_connection_string

# ==================================
# NEXTJS CONFIGURATION
# ==================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================================
# API KEYS (Add as needed)
# ==================================
# M-PESA DARAJA API (Get from https://developer.safaricom.co.ke)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=your_paybill_number
MPESA_PASSKEY=your_mpesa_passkey

# Payment Gateway Alternatives
# PAYNECTA CONFIGURATION
# ==================================
# Paynecta Mobile Payment (https://paynecta.co.ke)
PAYNECTA_API_KEY=your_paynecta_api_key
PAYNECTA_EMAIL=your_paynecta_account_email
PAYNECTA_CODE=your_paynecta_payment_link_code

# STRIPE_SECRET_KEY=your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ==================================
# EMAIL SERVICE (Optional)
# ==================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ==================================
# OTHER SERVICES
# ==================================
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
